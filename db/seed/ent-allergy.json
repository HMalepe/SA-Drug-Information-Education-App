  "safetyProfiles": [
    {
      "id": "safe-cetirizine",
      "moleculeId": "mol-cetirizine",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected severe allergic reaction / anaphylaxis is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [],
      "clinicalPearls": [
        {
          "value": "Second-generation agents are preferred when sedation must be minimised — still ask about alcohol and other sedatives.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "May still cause drowsiness in some people — test response before driving. Never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
      "id": "safe-chlorphenamine",
      "moleculeId": "mol-chlorphenamine",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing not published in Materia yet — confirm against labelled product / SA guidelines.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Marked sedation — avoid alcohol and other CNS depressants unless the clinician directs; do not invent a driving clearance.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [],
      "counsellingPoints": [
        {
          "value": "Warn about drowsiness and dry mouth. Escalate if combined with benzodiazepines or alcohol. Never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
      "id": "safe-xylometazoline",
      "moleculeId": "mol-xylometazoline",
