    {
      "id": "course-cetirizine",
      "moleculeId": "mol-cetirizine",
      "title": "Cetirizine — allergy counselling without inventing doses",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-cet-1",
          "order": 1,
          "title": "Sedating vs non-sedating",
          "body": "Second-generation antihistamines reduce but do not abolish drowsiness risk. Educational counselling: ask about driving and alcohol — Materia does not publish dosing numbers here.",
          "publishState": "published"
        },
        {
          "id": "lesson-cet-2",
          "order": 2,
          "title": "When first-generation meets benzodiazepines",
          "body": "Chlorphenamine–diazepam teaching is about escalating additive sedation to the clinician, not inventing a switch. Confirm against current SA guidance and the labelled products.",
          "publishState": "published"
        }
      ],
      "quiz": [
