  "courses": [
    {
      "id": "course-amox",
      "moleculeId": "mol-amox",
      "title": "Amoxicillin — understand the why",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-amox-1",
          "order": 1,
          "title": "The Story",
          "body": "Amoxicillin was developed to improve oral absorption versus earlier penicillins — a practical win for outpatient infection treatment.",
          "publishState": "published"
        },
        {
          "id": "lesson-amox-2",
          "order": 2,
          "title": "Chemical Structure",
          "body": "Tap the beta-lactam ring in your mind: that four-membered ring is the business end that blocks cell-wall builders.",
          "publishState": "published"
        },
        {
          "id": "lesson-amox-3",
          "order": 3,
          "title": "Mechanism of Action",
          "body": "Bacteria build a brick wall (peptidoglycan). Amoxicillin stops the bricklayers. Wall fails → cell bursts when it tries to grow.",
          "publishState": "published"
        },
        {
          "id": "lesson-amox-4",
          "order": 4,
          "title": "Inside the Body",
          "body": "ADME journey scaffold: swallowed → absorbed → distributed → works at infection site → cleared (kidney-focused for many penicillins). Details pending sourced PK publish.",
