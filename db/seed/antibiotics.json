  "molecules": [
    {
      "id": "mol-amox",
      "slug": "amoxicillin",
      "innName": "Amoxicillin",
      "className": "Beta-lactam antibiotic (aminopenicillin)",
      "atcCode": "J01CA04",
      "therapeuticArea": "antibiotics",
      "synonyms": ["amoxycillin", "amoxil"],
      "publishState": "published",
      "chemistrySummary": {
        "value": "Amoxicillin is an aminopenicillin with a beta-lactam ring that targets bacterial cell-wall synthesis machinery.",
        "sourceId": "src-materia-edu",
        "publishState": "published",
        "lastReviewed": "2026-07-01"
      },
      "moaSummary": {
        "value": "It binds penicillin-binding proteins, blocking peptidoglycan cross-linking so growing bacteria cannot maintain a stable cell wall.",
        "sourceId": "src-materia-edu",
        "publishState": "published",
        "lastReviewed": "2026-07-01"
      },
      "discoveryNote": {
        "value": "Developed as a broader-spectrum oral penicillin derivative to improve absorption versus earlier penicillins.",
        "sourceId": "src-materia-edu",
        "publishState": "published",
        "lastReviewed": "2026-07-01"
      }
    },
    {
