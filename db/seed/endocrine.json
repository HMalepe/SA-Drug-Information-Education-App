  "safetyProfiles": [
    {
      "id": "safe-levothyroxine",
      "moleculeId": "mol-levothyroxine",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing / TSH targets not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected thyroid storm / myxoedema emergency is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Consistency of brand and timing matters — absorption is reduced by iron, calcium, and some foods; escalate clinically; never invent spacing rules as prescriptions.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "Empty-stomach morning counselling is common teaching — confirm against the labelled product; lab follow-up stays clinician-directed.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Take consistently; ask about iron/calcium supplements and antacids. Never invent a dose change.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
