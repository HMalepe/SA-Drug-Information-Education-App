  "safetyProfiles": [
    {
      "id": "safe-enoxaparin",
      "moleculeId": "mol-enoxaparin",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing / mg/kg rules not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected major bleed / HIT emergency is a medical emergency — seek emergency care. Supportive management only in this seed; protamine conversations stay clinician-directed — no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Bleeding risk rises with NSAIDs, antiplatelets, and other anticoagulants — escalate clinically; never invent a bridging plan.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "Injection-site technique and rotating sites are core counselling — renal function conversations belong with the clinician.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Report unusual bruising, black stools, or severe headache. Ask about NSAIDs. Never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
