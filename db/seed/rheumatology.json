  "safetyProfiles": [
    {
      "id": "safe-methotrexate",
      "moleculeId": "mol-methotrexate",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a weekly dose or confuse with daily dosing.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected MTX overdose / severe cytopenia is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Weekly vs daily mix-ups are high-stakes — counsel the weekly rhythm and escalate infection or mouth-ulcer concerns clinically.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "Folic acid support and lab monitoring are clinician-directed — Materia does not invent schedules.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Confirm it is a WEEKLY medicine. Ask about trimethoprim combinations and pregnancy plans. Never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
