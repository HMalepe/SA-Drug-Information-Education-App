    {
      "id": "course-methotrexate",
      "moleculeId": "mol-methotrexate",
      "title": "Methotrexate — weekly without inventing doses",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-mtx-1",
          "order": 1,
          "title": "Weekly is the safety word",
          "body": "Rheumatology MTX is typically weekly. Educational counselling: confirm the day, watch for infection/mouth ulcers — Materia does not publish mg schedules here.",
          "publishState": "published"
        },
        {
          "id": "lesson-mtx-2",
          "order": 2,
          "title": "Trimethoprim combinations",
          "body": "Methotrexate–co-trimoxazole teaching is about escalating antifolate toxicity risk to the clinician, not inventing a switch. Confirm against current SA guidance and the labelled products.",
          "publishState": "published"
        }
      ],
      "quiz": [
        {
          "id": "quiz-mtx-1",
