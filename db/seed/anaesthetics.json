  "safetyProfiles": [
    {
      "id": "safe-lidocaine",
      "moleculeId": "mol-lidocaine",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing / maximum local anaesthetic doses not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected local anaesthetic systemic toxicity (LAST) / airway emergency is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "CNS and cardiac toxicity signs (tinnitus, perioral numbness, seizures, arrhythmia) need urgent escalation — never invent a lipid emulsion protocol.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "With/without adrenaline packs are not interchangeable for all sites — confirm the labelled product.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "For topical/dental use follow labelled directions; report ringing ears or metallic taste urgently. Never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
      "id": "safe-midazolam",
