      "id": "course-lidocaine",
      "moleculeId": "mol-lidocaine",
      "title": "Lidocaine — LAST vigilance without inventing doses",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-lido-1",
          "order": 1,
          "title": "Local is still systemic if absorbed",
          "body": "Tinnitus, perioral numbness, and seizures are educational red flags for LAST. Materia does not publish maximum mg/kg tables here.",
          "publishState": "published"
        },
        {
          "id": "lesson-lido-2",
          "order": 2,
          "title": "Benzodiazepines meet opioids",
          "body": "Midazolam–fentanyl teaching is about escalating additive respiratory depression to the clinician, not inventing a sedation recipe. Confirm against current SA guidance and the labelled products.",
          "publishState": "published"
        }
      ],
      "quiz": [
