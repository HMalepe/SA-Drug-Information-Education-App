  "safetyProfiles": [
    {
      "id": "safe-chloramphenicol-eye",
      "moleculeId": "mol-chloramphenicol-eye",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing / drop schedules not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose or duration.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected chemical eye injury / sudden vision loss is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Red-eye with pain, photophobia, or vision change needs clinician review — OTC antibiotic drops are not a substitute for diagnosis.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "Teach drop technique and avoid contaminating the bottle tip — contact-lens advice belongs to the labelled product and clinician.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Wash hands; do not touch the dropper to the eye. Ask about contact lenses. Never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
      "id": "safe-timolol-eye",
      "moleculeId": "mol-timolol-eye",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing not published in Materia yet — confirm against labelled product / SA guidelines.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Systemic beta-blockade can occur from eye drops — ask about asthma, bradycardia, and oral beta-blockers; escalate clinically.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [],
      "counsellingPoints": [
        {
          "value": "Punctal occlusion teaching reduces systemic absorption — do not invent a schedule. Escalate if breathless or very slow pulse.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
