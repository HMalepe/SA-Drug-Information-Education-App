  "safetyProfiles": [
    {
      "id": "safe-fluoxetine",
      "moleculeId": "mol-fluoxetine",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose or taper.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected overdose / acute psychiatric emergency is a medical emergency — seek emergency care and crisis support. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Activation, suicidal ideation conversations, and serotonin toxicity themes are counselling hooks — escalate clinically; Materia does not invent monitoring intervals.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "Long half-life means washout conversations matter before starting other serotonergic agents — confirm with the clinician; never invent a switch plan.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Benefit may take weeks; early side effects can precede mood lift. Ask about crisis contacts. Never invent a dose change.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
      "id": "safe-amitriptyline",
