  "safetyProfiles": [
    {
      "id": "safe-omeprazole",
      "moleculeId": "mol-omeprazole",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected severe overdose / acute GI emergency is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [],
      "clinicalPearls": [
        {
          "value": "Long-term PPI conversations often cover indication review, bone/magnesium/infection risk framing — escalate clinically; Materia does not invent monitoring intervals.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Swallow whole; take before food if that matches the labelled product. Ask about alarm symptoms (bleeding, weight loss, vomiting) — never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
