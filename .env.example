# Materia environment template — copy to .env.local (never commit secrets)

# API
PORT=4000
NODE_ENV=development
PUBLIC_WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Supabase (stub-friendly: leave blank to use in-memory/JSON seed store)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Auth (optional when Supabase unset — API uses stub sessions)
AUTH_STUB_MODE=true

# AI / RAG — grounded retrieval only; no patient identifiers
AI_PROVIDER=stub
OPENAI_API_KEY=
AI_REGION=za-or-eu-with-dpa

# Feature flags
ENABLE_DOSE_CALCULATOR=true
REQUIRE_CLINICAL_CONFIRMATION=true

# Billing (leave blank = stub checkout; Doc 6 ZAR prices)
# Live: set secret + public key; webhook POST /billing/webhook/paystack (HMAC SHA512)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_URL=http://localhost:4000/billing/webhook/paystack

# Messaging — reminders (leave blank = stub/local log only; Doc 16)
RESEND_API_KEY=
RESEND_FROM_EMAIL=reminders@materia.example
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
