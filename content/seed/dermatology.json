  "safetyProfiles": [
    {
      "id": "safe-hydrocortisone",
      "moleculeId": "mol-hydrocortisone",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing / application rules not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose or duration.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected severe allergic reaction / acute dermatology emergency is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Avoid prolonged use on the face/folds unless the clinician directs — escalate if infection is suspected under a steroid.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "Potency ladder teaching (mild → very potent) matters more than brand names at the counter — confirm the labelled strength.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Apply thinly to affected skin; wash hands after. Ask about broken skin or infection. Never invent a course length.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
      "id": "safe-isotretinoin",
