    {
      "id": "course-hydrocortisone",
      "moleculeId": "mol-hydrocortisone",
      "title": "Hydrocortisone — potency without inventing doses",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-hc-1",
          "order": 1,
          "title": "Mild ≠ harmless forever",
          "body": "Even mild topical steroids need site and duration awareness. Educational counselling: thin application, watch for infection under occlusion — Materia does not publish finger-tip quantities here.",
          "publishState": "published"
        },
        {
          "id": "lesson-hc-2",
          "order": 2,
          "title": "When acne therapy gets systemic",
          "body": "Isotretinoin–doxycycline teaching is about escalating intracranial hypertension risk to the clinician, not inventing a switch. Confirm against current SA guidance and the labelled products.",
          "publishState": "published"
        }
      ],
      "quiz": [
