  "courses": [
    {
      "id": "course-levonorgestrel",
      "moleculeId": "mol-levonorgestrel",
      "title": "Levonorgestrel — contraception counselling without inventing doses",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-lng-1",
          "order": 1,
          "title": "Emergency vs ongoing contraception",
          "body": "Levonorgestrel appears in EC packs and long-acting devices. Educational counselling: clarify the product in hand, STI protection limits, and escalate for ongoing method choice — Materia does not publish timing windows here.",
          "publishState": "published"
        },
        {
          "id": "lesson-lng-2",
          "order": 2,
          "title": "Enzyme inducers and reliability",
          "body": "Rifampicin–hormonal contraception teaching is about escalating reduced reliability to the clinician, not inventing a backup pill schedule. Confirm against current SA guidance and the labelled products.",
          "publishState": "published"
        }
      ],
      "quiz": [
        {
          "id": "quiz-lng-1",
          "prompt": "A patient on rifampicin asks about her combined pill. Best educational frame?",
          "choices": [
            "Double the pill tonight",
            "Flag enzyme-induction risk and escalate clinically — do not invent a dose or backup schedule",
            "Stop rifampicin without advice",
            "Switch brands randomly"
          ],
          "correctIndex": 1,
          "teachFromMiss": "Interaction counselling means escalate — Materia never invents contraceptive dose or timing rules.",
          "publishState": "published"
        }
      ]
    }
