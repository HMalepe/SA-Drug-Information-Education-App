  "safetyProfiles": [
    {
      "id": "safe-levonorgestrel",
      "moleculeId": "mol-levonorgestrel",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing / timing rules not published in Materia yet — confirm against labelled product / SA guidelines. Do not invent a dose or EC window.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected overdose / acute gynaecological emergency is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "Emergency contraception does not protect against STIs and is not ongoing contraception — escalate for ongoing method counselling.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "Enzyme-inducing medicines (e.g. rifampicin) can reduce hormonal contraceptive reliability — educational flag only; never invent a backup schedule.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Ask about time since unprotected sex, vomiting after a dose, and ongoing contraception needs. Never invent timing or dose advice.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
