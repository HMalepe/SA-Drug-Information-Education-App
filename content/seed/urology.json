      },
      "antidoteOrSupportive": {
        "value": "Suspected acute urinary retention / severe hypotension is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "First-dose dizziness / orthostasis and cataract (floppy iris) history are counselling themes — escalate clinically.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [],
      "counsellingPoints": [
        {
          "value": "Take as labelled; rise slowly if dizzy. Ask about PDE5 inhibitors. Never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
