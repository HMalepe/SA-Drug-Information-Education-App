      "moleculeId": "mol-rifampicin",
      "title": "Rifampicin — orange urine & enzyme induction",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-rif-1",
          "order": 1,
          "title": "Expected colour change",
          "body": "Orange-red urine, tears, and sweat can alarm patients. Teaching that this is expected improves adherence — educational framing only.",
          "publishState": "published"
        },
        {
          "id": "lesson-rif-2",
          "order": 2,
          "title": "Why ART + TB is high stakes",
          "body": "Rifampicin induces drug-metabolising enzymes. Some ART exposures fall — Materia flags the interaction educationally and refuses to invent dose changes.",
          "publishState": "published"
        }
      ],
