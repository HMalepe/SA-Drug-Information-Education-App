  "safetyProfiles": [
    {
      "id": "safe-tamoxifen",
      "moleculeId": "mol-tamoxifen",
      "publishState": "published",
      "dosingAdult": {
        "value": "Adult dosing / duration not published in Materia yet — confirm against labelled product / oncology team. Do not invent a dose.",
        "sourceId": "src-materia-edu",
        "publishState": "draft"
      },
      "antidoteOrSupportive": {
        "value": "Suspected VTE / acute oncology emergency is a medical emergency — seek emergency care. Supportive management only in this seed; no specific antidote protocol published here.",
        "sourceId": "src-materia-edu",
        "publishState": "published"
      },
      "contraindications": [],
      "warnings": [
        {
          "value": "VTE risk and hot-flush counselling are common themes — CYP2D6 inhibitor combinations can reduce activation; escalate clinically.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "clinicalPearls": [
        {
          "value": "Strong CYP2D6 inhibitors (e.g. some SSRIs) may matter for tamoxifen activation — educational flag only; never invent a switch.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ],
      "counsellingPoints": [
        {
          "value": "Take consistently; report leg swelling, chest pain, or unusual vaginal bleeding. Never invent a dose.",
          "sourceId": "src-materia-edu",
          "publishState": "published"
        }
      ]
    },
    {
