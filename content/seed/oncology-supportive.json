      "title": "Tamoxifen — CYP2D6 without inventing doses",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-tam-1",
          "order": 1,
          "title": "Hormone therapy is not optional counselling",
          "body": "Adherence, hot flushes, and VTE warning signs are core educational themes. Materia does not publish duration or mg targets here.",
          "publishState": "published"
        },
        {
          "id": "lesson-tam-2",
          "order": 2,
          "title": "SSRIs that inhibit CYP2D6",
          "body": "Tamoxifen–fluoxetine teaching is about escalating reduced activation risk to the clinician, not inventing a switch. Confirm against current oncology guidance and the labelled products.",
          "publishState": "published"
        }
      ],
