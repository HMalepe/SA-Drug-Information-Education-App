  "courses": [
    {
      "id": "course-amlodipine",
      "moleculeId": "mol-amlodipine",
      "title": "Amlodipine — why ankles swell",
      "publishState": "published",
      "lessons": [
        {
          "id": "lesson-amlo-1",
          "order": 1,
          "title": "Dihydropyridine vs non-DHP",
          "body": "Amlodipine preferentially relaxes arteries. That helps blood pressure but can increase capillary pressure in the legs — educational framing for ankle oedema counselling.",
          "publishState": "published"
        },
        {
          "id": "lesson-amlo-2",
          "order": 2,
          "title": "Adherence beats perfection",
          "body": "Missed doses and sudden stops matter. Materia does not publish numeric regimens here — confirm against the labelled product and the clinician's plan.",
          "publishState": "published"
        }
      ],
      "quiz": [
        {
          "id": "quiz-amlo-1",
          "prompt": "A patient on amlodipine reports new ankle swelling. Best first educational frame?",
          "choices": [
            "It means the medicine is not working — stop immediately",
